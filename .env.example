# Placeholder — Environment variables for development
# Copy this file to .env and fill in real values. .env is gitignored.

# =============================================================================
# CORE (required for the app to boot)
# =============================================================================
SECRET_KEY_BASE=
PHX_HOST=localhost
PORT=4000

# ParadeDB / Postgres (docker-compose.yml spins this up on localhost:5432)
DATABASE_URL=ecto://colloq:colloq@localhost/colloq_dev
POOL_SIZE=10

# =============================================================================
# FOOTBALL DATA
# =============================================================================
API_FOOTBALL_KEY=
FOOTBALL_DATA_API_KEY=

# =============================================================================
# LLM PROVIDERS — Free tiers available, no CC needed for most
# =============================================================================
GROQ_API_KEY=
NVIDIA_NIM_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# =============================================================================
# STORAGE (dev uses ImgBB, prod uses BunnyCDN)
# =============================================================================
IMGBB_API_KEY=
BUNNY_API_KEY=
BUNNY_STORAGE_ZONE=

# =============================================================================
# OAUTH (optional — social login)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# WEB PUSH (PWA notifications)
# Generate with: mix web_push_encryption.gen_keys
# =============================================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# =============================================================================
# EMAIL (dev uses local adapter, prod uses SMTP)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# =============================================================================
# RELEASE
# =============================================================================
RELEASE_COOKIE=colloq-release-cookie-change-in-prod
