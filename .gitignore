# https://git-scm.com/docs/gitignore

# Elixir / Mix
/_build/
/cover/
/deps/
/doc/
/.fetch
elixir_ls
*.beam
/config/*.secret.exs
*.ez
erl_crash.dump

# Environment
.env
.env.*
!.env.example
*.pem
*.key

# Generated files
/node_modules/
/assets/node_modules/
priv/static/assets/
priv/static/cache_manifest.json

# Runtime uploads (composer images are written to priv/static/uploads).
# Source assets — favicon.svg, icons/, images/, emojis/ — stay tracked.
/priv/static/uploads/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Database
*.dump
*.sql

# Temporary
/tmp/
/.elixir_ls/
/.sobelow

# Release artifacts (kept in systemd/ but not built here)
/rel/

# Docker volumes
pgdata/

# Spam-classifier ML model artifacts (baked into the Docker image at build
# time via the Dockerfile — never committed to the repo).
spam_classifier/models/
*.onnx

# Local uploads (dev/test)
/tmp/colloq_uploads/

# E2E trace artifacts
test/e2e/traces/
test/e2e/screenshots/
