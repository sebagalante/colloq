<section class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-white">Bots</h1>
    <.button phx-click="open-new">Nuevo Bot</.button>
  </div>

  <%= if @personas == [] do %>
    <.card>
      <p class="text-sm text-gray-400">No hay bots configurados. Creá una persona bot para empezar.</p>
    </.card>
  <% else %>
    <div class="space-y-3">
      <%= for persona <- @personas do %>
        <.card class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[#1a2035] flex items-center justify-center text-lg overflow-hidden">
              <%= if Map.get(persona.config || %{}, "avatar_url") != "" do %>
                <img src={persona.config["avatar_url"]} alt={persona.name} class="w-full h-full object-cover" />
              <% else %>
                🤖
              <% end %>
            </div>
            <div>
              <p class="text-sm font-semibold text-white"><%= persona.name %></p>
              <p class="text-xs text-gray-500">@<%= persona.slug %></p>
            </div>
          </div>

          <div class="flex items-center gap-2">
            <.badge color={if persona.active, do: "green", else: "gray"}>
              <%= if persona.active, do: "Activo", else: "Inactivo" %>
            </.badge>
            <button phx-click="edit" phx-value-id={persona.id} class="text-gray-400 hover:text-white text-sm">
              Editar
            </button>
            <button
              phx-click="delete"
              phx-value-id={persona.id}
              data-confirm="¿Eliminar este bot?"
              class="text-red-400 hover:text-red-300 text-sm"
            >
              Eliminar
            </button>
          </div>
        </.card>
      <% end %>
    </div>
  <% end %>

  <.modal id="bot-modal" show={@show_modal} on_cancel={JS.push("close-modal")}>
    <:title><%= if @editing, do: "Editar Bot", else: "Nuevo Bot" %></:title>

    <form phx-submit="save" class="space-y-4 max-h-[70vh] overflow-y-auto pr-1">
      <input type="hidden" name="bot[active]" value={@form.active} />

      <.input label="Nombre" name="bot[name]" value={@form.name} required />
      <.input label="Slug" name="bot[slug]" value={@form.slug} required placeholder="nombre-del-bot" />
      <.input label="URL del Avatar" name="bot[avatar_url]" value={@form.avatar_url} />
      <.input label="Descripción" name="bot[description]" value={@form.description} />

      <.textarea
        label="System Prompt"
        name="bot[system_prompt]"
        value={@form.system_prompt}
      />

      <div class="grid grid-cols-2 gap-4">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-1">Proveedor</label>
          <select
            name="bot[provider]"
            class="w-full rounded-lg border border-[#1a2035] bg-[#0f1420] text-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
            <option value="groq" selected={@form.provider == "groq"}>Groq</option>
            <option value="nvidia" selected={@form.provider == "nvidia"}>NVIDIA NIM</option>
            <option value="anthropic" selected={@form.provider == "anthropic"}>Anthropic</option>
            <option value="openrouter" selected={@form.provider == "openrouter"}>OpenRouter</option>
          </select>
        </div>

        <.input label="Modelo" name="bot[model]" value={@form.model} />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <.input label="Temperatura" name="bot[temperature]" value={@form.temperature} type="number" step="0.1" />
        <.input label="Max Tokens" name="bot[max_tokens]" value={@form.max_tokens} type="number" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="mb-4 flex items-center gap-2 pt-5">
          <input
            type="checkbox"
            name="bot[trigger_on_mention]"
            value="true"
            checked={@form.trigger_on_mention == "true"}
            class="rounded border-[#1a2035] bg-[#0f1420] text-blue-600 focus:ring-blue-500"
          />
          <label class="text-sm text-gray-300">Responder al ser mencionado</label>
        </div>

        <.input label="Nivel de Confianza Requerido" name="bot[allowed_trust_level]" value={@form.allowed_trust_level} type="number" min="0" max="4" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <.input label="Rate Limit por Usuario" name="bot[rate_limit_per_user]" value={@form.rate_limit_per_user} type="number" />

        <div class="mb-4 flex items-center gap-2 pt-5">
          <input
            type="checkbox"
            name="bot[managed_by_worker]"
            value="true"
            checked={@form.managed_by_worker == "true"}
            class="rounded border-[#1a2035] bg-[#0f1420] text-blue-600 focus:ring-blue-500"
          />
          <label class="text-sm text-gray-300">Gestionado por Worker</label>
        </div>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <.button type="submit">Guardar</.button>
        <.button type="button" class="bg-gray-700 hover:bg-gray-600" phx-click="close-modal">Cancelar</.button>
      </div>
    </form>
  </.modal>

  <.card class="mt-6">
    <h3 class="text-lg font-semibold text-white mb-3">Probar Prompt</h3>

    <form phx-submit="test" class="space-y-3">
      <div class="grid grid-cols-2 gap-4">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-300 mb-1">Proveedor</label>
          <select
            name="provider"
            class="w-full rounded-lg border border-[#1a2035] bg-[#0f1420] text-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
            <option value="groq">Groq</option>
            <option value="nvidia">NVIDIA NIM</option>
            <option value="anthropic">Anthropic</option>
            <option value="openrouter">OpenRouter</option>
          </select>
        </div>
        <.input label="Modelo" name="model" value="gpt-4o-mini" />
      </div>

      <.textarea label="System Prompt" name="system_prompt" value={@form[:system_prompt] || ""} />

      <.textarea label="Prompt de prueba" name="prompt" value="" placeholder="Escribí un mensaje de prueba..." />

      <.button type="submit" disabled={@test_loading}>
        <%= if @test_loading, do: "Probando...", else: "Probar" %>
      </.button>
    </form>

    <%= if @test_response do %>
      <div class="mt-4 p-3 rounded-lg bg-[#1a2035] border border-[#253048]">
        <p class="text-xs text-gray-400 mb-1">Respuesta:</p>
        <p class="text-sm text-white whitespace-pre-wrap"><%= @test_response %></p>
      </div>
    <% end %>
  </.card>
</section>
