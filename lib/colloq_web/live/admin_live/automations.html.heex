<section class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-heading"><%= gettext("Automations") %></h1>
    <.button phx-click="open-new"><%= gettext("New Automation") %></.button>
  </div>

  <%= if @automations == [] do %>
    <.card>
      <p class="text-sm text-muted"><%= gettext("No automations configured. Create one to get started.") %></p>
    </.card>
  <% else %>
    <div class="space-y-3">
      <%= for auto <- @automations do %>
        <.card class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button
              phx-click="toggle"
              phx-value-id={auto.id}
              class={[
                "relative inline-flex h-6 w-11 items-center rounded-full transition-colors",
                auto.enabled && "bg-accent",
                !auto.enabled && "bg-gray-700"
              ]}
            >
              <span class={[
                "inline-block h-4 w-4 transform rounded-full bg-white transition-transform",
                auto.enabled && "translate-x-6",
                !auto.enabled && "translate-x-1"
              ]}></span>
            </button>

            <div>
              <p class="text-sm font-semibold text-heading"><%= auto.name %></p>
              <p class="text-xs text-muted">
                Trigger: <%= auto.trigger %> ·
                Script: <%= auto.script %>
              </p>
            </div>
          </div>

          <div class="flex items-center gap-2">
            <.badge color={if auto.enabled, do: "green", else: "gray"}>
              <%= if auto.enabled, do: gettext("Active"), else: gettext("Inactive") %>
            </.badge>
            <button phx-click="edit" phx-value-id={auto.id} class="text-muted hover:text-heading text-sm">
              <%= gettext("Edit") %>
            </button>
            <button
              phx-click="delete"
              phx-value-id={auto.id}
              data-confirm={gettext("Delete this automation?")}
              class="text-danger hover:text-danger text-sm"
            >
              <%= gettext("Delete") %>
            </button>
          </div>
        </.card>
      <% end %>
    </div>
  <% end %>

  <.modal id="automation-modal" show={@show_modal} on_cancel={JS.push("close-modal")}>
    <:title><%= if @editing, do: gettext("Edit Automation"), else: gettext("New Automation") %></:title>

    <form phx-submit="save" class="space-y-4">
      <input type="hidden" name="automation[enabled]" value="true" />

      <.input
        label={gettext("Name")}
        name="automation[name]"
        value={@form.name}
        required
      />

      <div class="mb-4">
        <label class="block text-sm font-medium text-body mb-1">Trigger</label>
        <select
          name="automation[trigger]"
          class="w-full rounded-lg border border-border bg-surface text-heading px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
        >
          <option value="recurring" selected={@form.trigger == "recurring"}><%= gettext("Periodic") %></option>
          <option value="user_registered" selected={@form.trigger == "user_registered"}><%= gettext("User Registered") %></option>
          <option value="user_promoted" selected={@form.trigger == "user_promoted"}><%= gettext("User Promoted") %></option>
          <option value="post_created" selected={@form.trigger == "post_created"}><%= gettext("Post Created") %></option>
          <option value="stalled_topic" selected={@form.trigger == "stalled_topic"}><%= gettext("Stale Topic") %></option>
          <option value="point_in_time" selected={@form.trigger == "point_in_time"}><%= gettext("Point in Time") %></option>
          <option value="api_call" selected={@form.trigger == "api_call"}><%= gettext("API Call") %></option>
        </select>
      </div>

      <.textarea
        label={gettext("Trigger Config (JSON)")}
        name="automation[trigger_config]"
        value={@form.trigger_config}
      />

      <div class="mb-4">
        <label class="block text-sm font-medium text-body mb-1">Script</label>
        <select
          name="automation[script]"
          class="w-full rounded-lg border border-border bg-surface text-heading px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
        >
          <option value="send_pm" selected={@form.script == "send_pm"}><%= gettext("Send DM") %></option>
          <option value="create_post" selected={@form.script == "create_post"}><%= gettext("Create Post") %></option>
          <option value="llm_respond" selected={@form.script == "llm_respond"}><%= gettext("Reply with LLM") %></option>
          <option value="close_topic" selected={@form.script == "close_topic"}><%= gettext("Close Topic") %></option>
          <option value="pin_topic" selected={@form.script == "pin_topic"}><%= gettext("Pin Topic") %></option>
          <option value="flag_post" selected={@form.script == "flag_post"}><%= gettext("Report Post") %></option>
          <option value="auto_tag" selected={@form.script == "auto_tag"}><%= gettext("Auto Tag") %></option>
        </select>
      </div>

      <.textarea
        label={gettext("Script Config (JSON)")}
        name="automation[script_config]"
        value={@form.script_config}
      />

      <div class="flex items-center gap-3 pt-2">
        <.button type="submit"><%= gettext("Save") %></.button>
        <.button type="button" class="bg-gray-700 hover:bg-gray-600" phx-click="close-modal"><%= gettext("Cancel") %></.button>
      </div>
    </form>
  </.modal>
</section>
